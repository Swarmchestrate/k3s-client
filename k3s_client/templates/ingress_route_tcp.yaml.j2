apiVersion: traefik.io/v1alpha1
kind: IngressRouteTCP
metadata:
  name: {{ name | tojson }}
  {% if namespace %}
  namespace: {{ namespace | tojson }}
  {% endif %}
spec:
  entryPoints:
    {% for ep in entry_points %}
    - {{ ep | tojson }}
    {% endfor %}
  routes:
    - match: {{ match | tojson }}
      services:
        - name: {{ service_name | tojson }}
          port: {{ service_port }}
  tls:
    passthrough: {{ tls_passthrough | tojson }}
