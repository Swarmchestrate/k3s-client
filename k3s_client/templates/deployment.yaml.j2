apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ (name ~ '-' ~ version) | tojson }}
  labels:
    app: {{ (labels.app | default(name)) | tojson }}
    version: {{ version | tojson }}
    service: {{ (labels.app | default(name)) | tojson }}
spec:
  replicas: {{ replicas }}
  selector:
    matchLabels:
      app: {{ (labels.app | default(name)) | tojson }}
      version: {{ version | tojson }}
      service: {{ (labels.app | default(name)) | tojson }}
  template:
    metadata:
      labels:
        app: {{ (labels.app | default(name)) | tojson }}
        version: {{ version | tojson }}
        service: {{ (labels.app | default(name)) | tojson }}
      {% if annotations %}
      annotations:
        {% for k, v in annotations.items() %}
        {{ k }}: {{ v | tojson }}
        {% endfor %}
      {% endif %}
    spec:
      {% if service_account %}
      serviceAccountName: {{ service_account | tojson }}
      {% endif %}
      {% if image_pull_secret %}
      imagePullSecrets:
        - name: {{ image_pull_secret | tojson }}
      {% endif %}
      {% if node_selector %}
      nodeSelector:
        {% for k, v in node_selector.items() %}
        {{ k }}: {{ v | tojson }}
        {% endfor %}
      {% endif %}
      containers:
        - name: {{ (name ~ '-' ~ version) | tojson }}
          image: {{ image | tojson }}
          {% if command %}
          command:
            {% for c in command %}
            - {{ c | tojson }}
            {% endfor %}
          {% endif %}
          {% if args %}
          args:
            {% for a in args %}
            - {{ a | tojson }}
            {% endfor %}
          {% endif %}
          {% if env_list %}
          env:
            {% for e in env_list %}
            - name: {{ e.name | tojson }}
              value: {{ e.value | tojson }}
            {% endfor %}
          {% endif %}
          {% if container_ports %}
          ports:
            {% for p in container_ports %}
            - containerPort: {{ p.containerPort }}
              protocol: "{{ p.protocol }}"
            {% endfor %}
          {% endif %}
          {% if volume_mounts %}
          volumeMounts:
            {% for vm in volume_mounts %}
            - name: {{ vm.name | tojson }}
              mountPath: {{ vm.mountPath | tojson }}
              {% if vm.readOnly is defined and vm.readOnly %}
              readOnly: true
              {% endif %}
            {% endfor %}
          {% endif %}
      {% if volumes %}
      volumes:
        {% for v in volumes %}
        - name: {{ v.name | tojson }}
          {% if v.emptyDir is defined %}
          emptyDir: {}
          {% elif v.configMap is defined %}
          configMap:
            name: {{ v.configMap.name | tojson }}
          {% elif v.secret is defined %}
          secret:
            secretName: {{ v.secret.secretName | tojson }}
          {% elif v.persistentVolumeClaim is defined %}
          persistentVolumeClaim:
            claimName: {{ v.persistentVolumeClaim.claimName | tojson }}
          {% elif v.hostPath is defined %}
          hostPath:
            path: {{ v.hostPath.path | tojson }}
            {% if v.hostPath.type is defined %}
            type: {{ v.hostPath.type | tojson }}
            {% endif %}
          {% endif %}
        {% endfor %}
      {% endif %}